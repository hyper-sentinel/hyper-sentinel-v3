# Hyper-Sentinel v2 — Environment Configuration
# ====================================================
# Copy this to .env and fill in your values.
# Only LLM_PROVIDER + LLM_API_KEY are required to start.
# Everything else enables additional data sources and trading.

# ─── LLM Provider ──────────────────────────────────
# Options: CLAUDE | GEMINI | GROK | OLLAMA
LLM_PROVIDER=CLAUDE

# Model override (leave blank to use provider default)
# Defaults: anthropic/claude-sonnet-4-5 | google/gemini-2.0-flash | xai/grok-2 | ollama/deepseek-r1:1.5b
LLM_MODEL=

# API key for your chosen provider (not needed for OLLAMA)
LLM_API_KEY=sk-ant-...

# ─── Data Sources ──────────────────────────────────
# CoinGecko — no key needed (free API)

# FRED — Federal Reserve economic data (free)
# Get key at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Y2 — News sentiment + intelligence reports
# Get key at: https://y2.dev/app/developers/api-keys
Y2_API_KEY=

# Elfa AI — Social sentiment + trending tokens
# Get key at: https://docs.elfa.ai
ELFA_API_KEY=

# X (Twitter) — Tweet search + sentiment
# Get key at: https://developer.twitter.com
X_BEARER_TOKEN=

# ─── Trading (Optional) ───────────────────────────
# ⚠️ These enable REAL TRADING with REAL FUNDS

# Hyperliquid — perp futures
HYPERLIQUID_PRIVATE_KEY=
HYPERLIQUID_WALLET_ADDRESS=

# Aster DEX — futures trading
ASTER_API_KEY=
ASTER_API_SECRET=

# Polymarket — prediction markets
POLYMARKET_PRIVATE_KEY=

# ─── MCP Servers (Optional) ───────────────────────
# Brave Search
BRAVE_API_KEY=

# GitHub
GITHUB_TOKEN=

# PostgreSQL (for memory + Ops)
DATABASE_URL=postgresql://localhost:5432/hyper

# ─── Webhooks (Optional) ──────────────────────────
WEBHOOK_ENABLED=false
WEBHOOK_PORT=8888
WEBHOOK_SECRET=

# ─── Sentinel Autonomous Mode ─────────────────────
# Watchlist: comma-separated coin:threshold pairs
SENTINEL_WATCHLIST=bitcoin:5.0,ethereum:7.0,solana:8.0

# Trading guardrails
SENTINEL_MAX_TRADE_USD=100
SENTINEL_MAX_DAILY_TRADES=5
SENTINEL_MAX_DAILY_LOSS=250
SENTINEL_AUTO_EXECUTE=false

# Strategy Runner (SMA crossover)
STRATEGY_ENABLED=false
STRATEGY_SYMBOL=BTCUSDT
STRATEGY_FAST_SMA=9
STRATEGY_SLOW_SMA=21
STRATEGY_TRADE_USD=25

# ─── Telegram Notifications ──────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Client API (for reading channels)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# ─── Logging ───────────────────────────────────────
LOG_LEVEL=INFO
