# Hyper-Sentinel v2 — MarketAgent Environment Variables
# ======================================================
# Copy to .env and fill in your values.

# ─── NATS ──────────────────────────────────────────
# Docker: nats://nats:4222 | Local: nats://localhost:4222
NATS_URL=nats://localhost:4222

# ─── LLM Provider ─────────────────────────────────
# Options: CLAUDE | GEMINI | GROK | OLLAMA
LLM_PROVIDER=CLAUDE

# Model override (leave blank to use provider default)
# CLAUDE  → anthropic/claude-sonnet-4-5
# GEMINI  → google/gemini-2.0-flash
# GROK    → xai/grok-2
# OLLAMA  → ollama/deepseek-r1:1.5b
LLM_MODEL=

# API key for your chosen provider (not needed for OLLAMA)
LLM_API_KEY=sk-ant-...

# ─── Agent ─────────────────────────────────────────
AGENT_NAME=MarketAgent

# ─── Database ─────────────────────────────────────
# SQLite path for decision logging
DB_PATH=data/agent_decisions.db

# ─── Logging ──────────────────────────────────────
LOG_LEVEL=INFO

# ─── Ollama (only if LLM_PROVIDER=OLLAMA) ─────────
OLLAMA_HOST=http://localhost:11434
